<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Syarat &amp; Ketentuan"
            style="@style/Text.Title"
            android:textSize="18sp" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Syarat &amp; Ketentuan Penggunaan"
                        style="@style/Text.Title"
                        android:textSize="16sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Selamat datang di TaskMan. Harap baca Syarat dan Ketentuan ini secara saksama sebelum menggunakan aplikasi kami.\n\n1. Ketentuan Umum\nDengan mengakses dan menggunakan TaskMan, Anda dianggap telah menyetujui semua syarat dan ketentuan yang tercantum di sini.\n\n2. Akun Pengguna\nAnda bertanggung jawab sepenuhnya atas kerahasiaan kredensial akun Anda (email dan password) dan setiap aktivitas yang terjadi di bawah akun Anda.\n\n3. Penggunaan Layanan\nTaskMan menyediakan layanan pengelolaan tugas (task management). Layanan ini ditujukan hanya untuk penggunaan yang sah sesuai aturan hukum yang berlaku. Anda dilarang menyalahgunakan sistem dengan mengirimkan data berbahaya atau merusak infrastruktur.\n\n4. Hak Milik Intelektual\nSemua hak cipta, desain, logo, dan kode sumber dari aplikasi TaskMan adalah milik eksklusif kami dan dilindungi oleh undang-undang hak cipta.\n\n5. Pembatasan Tanggung Jawab\nKami berusaha sebaik mungkin menjaga kestabilan sistem, namun kami tidak bertanggung jawab atas hilangnya data akibat kendala teknis atau kelalaian pengguna."
                        style="@style/Text.Body"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.3" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
