<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/background"
    android:id="@+id/swipeRefresh"
    tools:context=".ui.auth.ProfileFragment">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/imgHeader"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_profil" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingVertical="@dimen/space_20"
            android:paddingHorizontal="@dimen/profile_padding_horizontal">

            <TextView
                android:layout_marginTop="36dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Profil"
                style="@style/Text.Title"
                android:textColor="@color/white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Kelola Informasi Akun Anda"
                style="@style/Text.Body"
                android:textColor="@color/white"/>

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmer_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:shimmer_auto_start="true"
                app:shimmer_base_alpha="0.7"
                app:shimmer_highlight_alpha="1.0"
                app:shimmer_duration="1000"
                android:layout_marginTop="@dimen/space_24"
                android:layout_marginHorizontal="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/space_16"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:padding="@dimen/space_16"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="92dp"
                                android:layout_height="92dp"
                                app:cardCornerRadius="46dp"
                                app:cardBackgroundColor="@color/shimmer_base"
                                app:cardElevation="0dp"
                                app:strokeWidth="0dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="@dimen/space_12"
                                android:orientation="vertical">

                                <View
                                    android:layout_marginTop="16dp"
                                    android:layout_width="140dp"
                                    android:layout_height="18dp"
                                    android:background="@color/shimmer_base" />

                                <View
                                    android:layout_marginTop="8dp"
                                    android:layout_width="80dp"
                                    android:layout_height="24dp"
                                    android:background="@color/shimmer_base" />

                                <View
                                    android:layout_marginTop="8dp"
                                    android:layout_width="110dp"
                                    android:layout_height="16dp"
                                    android:background="@color/shimmer_base" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_marginTop="24dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="@dimen/space_16"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_16">

                            <View
                                android:layout_width="120dp"
                                android:layout_height="16dp"
                                android:background="@color/shimmer_base" />

                            <View
                                android:layout_marginTop="16dp"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@color/shimmer_base" />

                            <View
                                android:layout_marginTop="12dp"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@color/shimmer_base" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.facebook.shimmer.ShimmerFrameLayout>



            <LinearLayout
                android:id="@+id/layout_profile_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_marginTop="@dimen/space_24"
                    android:layout_marginHorizontal="@dimen/space_16"
                    android:id="@+id/layoutProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/space_16"
                app:cardElevation="@dimen/space_4">

                <LinearLayout
                    android:padding="@dimen/space_16"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="92dp"
                        android:layout_height="92dp"
                        android:src="@drawable/ic_thumb_user"
                        app:civ_border_color="@color/white"
                        app:civ_border_width="2dp"
                        app:civ_circle_background_color="@color/background" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/space_12"
                        android:orientation="vertical">

                        <TextView
                            android:layout_marginTop="@dimen/space_12"
                            android:id="@+id/tvName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="........"
                            style="@style/Text.Title"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/background_secondary"
                            app:cardCornerRadius="@dimen/space_16"
                            app:cardElevation="0dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="@dimen/space_12"
                                android:paddingVertical="6dp"
                                android:orientation="horizontal">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_briefcase"/>
                                <TextView
                                    android:layout_marginStart="6dp"
                                    android:id="@+id/tvRole"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="-"
                                    style="@style/Text.Caption"
                                    android:textColor="@color/primary"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>


                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/space_12"
                            android:paddingVertical="6dp"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_office"/>
                            <TextView
                                android:layout_marginStart="6dp"
                                android:id="@+id/tvCompany"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                style="@style/Text.Caption" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:layout_marginTop="@dimen/space_24"
                android:layout_marginHorizontal="@dimen/space_16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/space_16"
                android:layout_marginBottom="@dimen/space_8"
                app:cardElevation="@dimen/space_4">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <RelativeLayout
                        android:id="@+id/layoutAkun"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:id="@+id/icUser"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/user_inactive"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icUser"
                            android:layout_marginStart="12dp"
                            android:text="Informasi Akun"
                            android:textSize="14sp"
                            android:textColor="#212121"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_arrow_right"/>
                    </RelativeLayout>

                    <TextView
                        android:layout_marginTop="@dimen/space_16"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengaturan &amp; Kebijakan"
                        android:textStyle="bold">
                    </TextView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_8"
                        android:background="@color/border" />

                    <RelativeLayout
                        android:id="@+id/layoutSyarat"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:id="@+id/icTerms"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_syarat"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icTerms"
                            android:layout_marginStart="12dp"
                            android:text="Syarat dan Ketentuan"
                            android:textSize="14sp"
                            android:textColor="#212121"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_arrow_right"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/layoutKebijakan"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:id="@+id/icPrivacy"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_privasi"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icPrivacy"
                            android:layout_marginStart="12dp"
                            android:text="Kebijakan Privasi"
                            android:textSize="14sp"
                            android:textColor="#212121"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_arrow_right"/>

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/border" />

                    <RelativeLayout
                        android:id="@+id/layoutLogout"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:paddingVertical="12dp"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:id="@+id/ivLogout"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_logout"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/ivLogout"
                            android:layout_marginStart="10dp"
                            android:text="Keluar"
                            android:textSize="14sp"
                            android:textColor="@color/delete_red"/>

                    </RelativeLayout>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>



</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>